# HuggingFace
HF_TOKEN=
HF_ENDPOINT=

# App mode
# deploy | dev
UNCOVERAI_MODE=deploy

# Security
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
CSP_CONNECT_SRC="'self' ws: wss:"
STRICT_ADMIN_AUTH=false
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=600
ADMIN_LOGIN_LOCK_SECONDS=900

# Server
HOST=0.0.0.0
PORT=8000

# Admin authentication
# Username for admin login (default: admin)
ADMIN_USERNAME=admin
# Plaintext password for dev default (overridden by ADMIN_PASSWORD_HASH if set)
ADMIN_PASSWORD=admin
# bcrypt hash of admin password — set this in production!
# Generate with: python3 -c "from backend.services.auth_service import hash_password; print(hash_password('yourpassword'))"
ADMIN_PASSWORD_HASH=
# JWT secret key — set a long random string in production!
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# JWT token lifetime in hours
JWT_EXPIRE_HOURS=24

# Frontend build/runtime mode switches
VITE_ENABLE_DEV_UI=true
VITE_DEFAULT_MODE=deploy
VITE_API_TARGET=http://202.117.43.131:8999
# Optional: make deploy frontend call a remote backend directly.
# Example: https://dev-api.example.com/api
VITE_PUBLIC_API_BASE_URL=

# Public user auth/quota persistence
PUBLIC_AUTH_DB_PATH=/home/lyf/.uncoverai/uncoverai_public.db
PUBLIC_DEFAULT_USER_DAILY_LIMIT=20
PUBLIC_GUEST_DAILY_LIMIT=3
PUBLIC_TOKEN_EXPIRE_HOURS=168
PUBLIC_QUOTA_TIMEZONE=Asia/Shanghai

# Runtime file lifecycle (managed upload/download tokens)
MGT_EVAL_RUNTIME_FILE_ROOT=/home/lyf/.mgt_eval/runtime_files
MGT_EVAL_OUTPUT_TTL_HOURS=72
MGT_EVAL_UPLOAD_TTL_HOURS=24
MGT_EVAL_FILE_CLEANUP_INTERVAL_SECONDS=600
